# ─── Database ────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/syntaxcore_workforce
DB_USERNAME=syntaxcore
DB_PASSWORD=your_strong_password_here

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your-minimum-64-character-random-secret-key-here-change-this-now-in-production
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ─── Email ───────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_HEALTH_ENABLED=false

# ─── Server ──────────────────────────────────────────────────
SERVER_PORT=8080
FRONTEND_URL=http://localhost:4200
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# ─── App ─────────────────────────────────────────────────────
FILE_UPLOAD_DIR=./uploads

# ─── OTP ─────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3

# ─── Twilio SMS (optional) ───────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── OpenAI (optional) ───────────────────────────────────────
OPENAI_API_KEY=
